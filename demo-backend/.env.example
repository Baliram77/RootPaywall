# Rootstock JSON-RPC URL (testnet). If you get ETIMEDOUT, try: https://rootstock-testnet.drpc.org
ROOTSTOCK_RPC_URL=https://public-node.testnet.rsk.co

# Your Rootstock address to receive tRBTC payments
MERCHANT_ADDRESS=0xYourRootstockAddress

# Secret for signing JWT access tokens (use a strong value in production)
JWT_SECRET=your-jwt-secret

# Private key for signing 402 payment details (MITM protection). Required.
# Must correspond to NEXT_PUBLIC_MERCHANT_SIG_SIGNER in frontend/.env.local.
MERCHANT_SIG_PRIVATE_KEY=0x...

# Confirmations required before unlock:
# - Local demo: 1 (fast)
# - Production: 6+ (safer against reorgs/double-spends)
MIN_CONFIRMATIONS=1

# Allowed frontend origin for CORS (set to your deployed frontend URL in production)
FRONTEND_URL=http://localhost:3001

# Redis for cluster-wide claims + rate limits (required in production unless X402_SINGLE_INSTANCE=true)
# X402_REDIS_URL=redis://localhost:6379

# Single-node production opt-in (file store — not safe for multiple replicas)
# X402_SINGLE_INSTANCE=true

# Reverse proxy trust (auto-enabled in production unless X402_TRUST_PROXY=false)
# X402_TRUST_PROXY=true

# Optional: server port (default 3000)
# PORT=3000
