# Rootstock JSON-RPC URL (testnet). If you get ETIMEDOUT, try: https://rootstock-testnet.drpc.org
ROOTSTOCK_RPC_URL=https://public-node.testnet.rsk.co

# Your Rootstock address to receive tRBTC payments
MERCHANT_ADDRESS=0xYourRootstockAddress

# Secret for signing JWT access tokens (use a strong value in production)
JWT_SECRET=your-jwt-secret

# Optional: server port (default 3000)
# PORT=3000
