# Backend API base URL (demo-backend server)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# Merchant signing address (must match address derived from demo-backend MERCHANT_SIG_PRIVATE_KEY).
# Required in production builds (NODE_ENV=production) — payment flow refuses unsigned 402 without this.
NEXT_PUBLIC_MERCHANT_SIG_SIGNER=0xYourMerchantSignerAddress
