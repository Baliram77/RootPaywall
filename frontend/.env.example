# Backend API base URL (demo-backend server)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# Required: public address of the account used for MERCHANT_SIG_PRIVATE_KEY in demo-backend/.env
NEXT_PUBLIC_MERCHANT_SIG_SIGNER=0xREPLACE_WITH_SIGNER_PUBLIC_ADDRESS
